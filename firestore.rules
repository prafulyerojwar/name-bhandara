rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── users ──────────────────────────────────────────────────────────────
    // Any authenticated user can create/read/update their own profile doc.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── bhandaras ──────────────────────────────────────────────────────────
    // Anyone logged in can read all bhandaras.
    // Only the donor who owns it can create / update / delete their own.
    match /bhandaras/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.donorId == request.auth.uid;
      allow update: if request.auth != null
                    && (resource.data.donorId == request.auth.uid
                        || isNgo());
      allow delete: if request.auth != null
                    && resource.data.donorId == request.auth.uid;
    }

    // ── bookings ────────────────────────────────────────────────────────────
    // NGO can create bookings for themselves.
    // Both the NGO and the bhandara donor can read / update a booking.
    match /bookings/{id} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.ngoId == request.auth.uid;
      allow update: if request.auth != null
                    && (resource.data.ngoId == request.auth.uid || isNgo());
      allow delete: if request.auth != null
                    && resource.data.ngoId == request.auth.uid;
    }

    // Helper: check if the caller's user doc has role == 'ngo'
    function isNgo() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ngo';
    }
  }
}
